{
  "atom-workspace": {
    "alt-u": "open-external:toggle"
  },
  ".tree-view": {
    "alt-enter": "open-external:open",
    "ctrl-enter": "open-external:show",
    "e": "open-external:toggle"
  },
  "atom-text-editor:not([mini]), .image-view, .image-editor, .pdf-viewer, .tree-view": {
    "alt-f12": "open-external:open",
    "ctrl-f12": "open-external:show"
  }
}
