{
  "name": "line-ending-selector",
  "author": "lumine-code",
  "version": "1.0.0",
  "main": "./lib/main",
  "description": "Select the line ending to use for the current editor.",
  "license": "MIT",
  "repository": "https://github.com/lumine-code/lumine",
  "engines": {
    "atom": "*"
  },
  "dependencies": {
    "@lumine-code/select-list": "https://github.com/lumine-code/select-list.git#ce68df17b97d2bab99f4e0bd5ce45001922c167d",
    "@lumine-code/underscore-plus": "https://github.com/lumine-code/underscore-plus.git#2b75d264c2ca01d27ee69d7cd05610a097011274"
  },
  "consumedServices": {
    "status-bar": {
      "versions": {
        "^1.0.0": "consumeStatusBar"
      }
    }
  },
  "configSchema": {
    "defaultLineEnding": {
      "order": 1,
      "title": "Default line ending",
      "description": "Line ending to use for new files",
      "type": "string",
      "enum": [
        "OS Default",
        "LF",
        "CRLF"
      ],
      "default": "OS Default"
    }
  }
}
