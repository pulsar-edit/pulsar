{
  "name": "line-ending-selector",
  "author": "lumine-code",
  "version": "1.0.0",
  "main": "./lib/main",
  "description": "Select the line ending to use for the current editor.",
  "license": "MIT",
  "repository": "https://github.com/lumine-code/lumine",
  "engines": {
    "atom": "*"
  },
  "dependencies": {
    "select-list": "file:../../shared/select-list",
    "underscore-plus": "^1.7.0"
  },
  "consumedServices": {
    "status-bar": {
      "versions": {
        "^1.0.0": "consumeStatusBar"
      }
    }
  },
  "configSchema": {
    "defaultLineEnding": {
      "order": 1,
      "title": "Default line ending",
      "description": "Line ending to use for new files",
      "type": "string",
      "enum": [
        "OS Default",
        "LF",
        "CRLF"
      ],
      "default": "OS Default"
    }
  }
}
