{
  ".source.sql": {
    "language": {
      "commentStart": "-- ",
      "commentDelimiters": {
        "line": "--"
      },
      "foldEndPattern": "^\\s*\\)",
      "increaseIndentPattern": "^\\s*(create|grant|insert|delete|update)\\b|\\((?!.*\\))",
      "decreaseIndentPattern": "^\\s*\\)(?!=.*\\()"
    }
  }
}
