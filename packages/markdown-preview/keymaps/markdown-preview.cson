'atom-text-editor':
  'ctrl-shift-m': 'markdown-preview:toggle'

'.markdown-preview':
  'cmdorctrl-a': 'markdown-preview:select-all'
  'cmdorctrl-+': 'markdown-preview:zoom-in'
  'cmdorctrl-=': 'markdown-preview:zoom-in'
  'cmdorctrl--': 'markdown-preview:zoom-out'
  'cmdorctrl-_': 'markdown-preview:zoom-out'
  'cmdorctrl-0': 'markdown-preview:reset-zoom'
